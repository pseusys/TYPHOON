FROM python:3.12-alpine

RUN apk add --no-cache iproute2 \
    && pip install --no-cache-dir dnslib==0.9.24

COPY evaluation/background/common/ /common/
COPY evaluation/background/dns/dns_client.py /usr/local/bin/dns_client
RUN chmod +x /usr/local/bin/dns_client

CMD ["python3", "/usr/local/bin/dns_client"]
