FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        iproute2 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=transport /usr/local/bin/tcp-sink /usr/local/bin/tcp-sink
HEALTHCHECK --interval=1s --timeout=3s --retries=15 --start-period=2s \
    CMD ss -tln | grep -q ':9000'
CMD ["tcp-sink"]
