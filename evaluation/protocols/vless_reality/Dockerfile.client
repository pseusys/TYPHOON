FROM ghcr.io/xtls/xray-core AS xray

FROM debian:bookworm-slim
COPY --from=xray /usr/local/bin/xray /usr/local/bin/xray
RUN apt-get update && apt-get install -y --no-install-recommends \
        iproute2 python3 python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir --break-system-packages PySocks \
    && mkdir -p /etc/xray
COPY vless_reality/client-entrypoint.sh /entrypoint.sh
COPY common/socks5_sender.py /app/client.py
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
