FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates iproute2 python3 python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir --break-system-packages PySocks \
    && curl -fsSL \
       https://github.com/apernet/hysteria/releases/download/app%2Fv2.6.1/hysteria-linux-amd64 \
       -o /usr/local/bin/hysteria \
    && chmod +x /usr/local/bin/hysteria
COPY hysteria2/client-entrypoint.sh /entrypoint.sh
COPY common/socks5_sender.py         /app/client.py
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
