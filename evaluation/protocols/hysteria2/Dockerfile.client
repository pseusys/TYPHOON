FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates iproute2 \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL \
       https://github.com/apernet/hysteria/releases/download/app%2Fv2.6.1/hysteria-linux-amd64 \
       -o /usr/local/bin/hysteria \
    && chmod +x /usr/local/bin/hysteria
COPY hysteria2/client-entrypoint.sh /entrypoint.sh
COPY --from=transport /usr/local/bin/socks5-sender /usr/local/bin/socks5-sender
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
