FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        shadowsocks-libev iproute2 python3 python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir --break-system-packages PySocks
COPY shadowsocks/client-entrypoint.sh /entrypoint.sh
COPY common/socks5_sender.py /app/client.py
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
