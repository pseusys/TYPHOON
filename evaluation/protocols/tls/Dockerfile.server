FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        iproute2 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=transport /usr/local/bin/tls-sink /usr/local/bin/tls-sink
HEALTHCHECK --interval=1s --timeout=3s --retries=20 --start-period=3s \
    CMD ss -tln | grep -q ':9000' && test -f /keys/tls_cert.pem
CMD ["tls-sink"]
